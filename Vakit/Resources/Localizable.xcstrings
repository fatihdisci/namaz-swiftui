    "safar.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calculate the direct distance between your home city and current location."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ev şehriniz ile anlık konumunuz arasındaki kuş uçuşu mesafeyi hesaplayın."
          }
        }
      }
    },
    "safar.disclaimer" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This information is for educational purposes only and does not constitute a religious ruling (fatwa). For definitive guidance, consult the Diyanet or a qualified religious authority."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu bilgiler bilgilendirme amaçlıdır, fetva niteliği taşımaz. Kesin hüküm için Diyanet İşleri Başkanlığı'na veya yetkili bir din görevlisine danışınız."
          }
        }
      }
    },
    "safar.distance" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ km"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ km"
          }
        }
      }
    },
    "safar.distanceFromHome" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are %@ km from your home city."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ev şehrinize %@ km uzaktasınız."
          }
        }
      }
    },
    "safar.homeCity" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Home city"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ev şehri"
          }
        }
      }
    },
    "safar.infoDistance" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This distance is the modern equivalent of the Hanafi \"three-day journey\" (approximately 18 farsakhs). Today, journeys of 90 km or more by road are considered within the scope of travel rulings. Different schools of thought may have varying opinions on distance and duration."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu mesafe, Hanefî fıkhındaki \"üç günlük yol\" (yaklaşık 18 fersah) ölçüsünün modern karşılığıdır. Günümüzde kara yolu ile 90 km ve üzeri mesafeye yapılan yolculuklar seferîlik kapsamında değerlendirilir. Mezhepler arasında mesafe ve süre konusunda farklı görüşler bulunabilir."
          }
        }
      }
    },
    "safar.infoPrayer" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A traveler shortens (qasr) the 4-rakat obligatory prayers to 2 rakats. There are also concessions regarding sunnah prayers. Traveler status continues during the journey and at the destination if staying fewer than 15 days."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seferî olan kişi, 4 rekatlı farz namazları 2 rekat olarak kısaltarak (kasr) kılar. Sünnet namazlar konusunda da kolaylıklar bulunur. Seferîlik hali, yolculuk süresince ve varış yerinde 15 günden az kalmak şartıyla devam eder."
          }
        }
      }
    },
    "safar.infoSource" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Source: Diyanet (Presidency of Religious Affairs, Turkey) — Qur'an, An-Nisa 4:101; Hanafi jurisprudence (Ibn Abidin, Radd al-Muhtar)."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaynak: Diyanet İşleri Başkanlığı — Kur'an-ı Kerim, Nisâ Suresi 4:101; Hanefî fıkhı (İbn Âbidîn, Reddü'l-Muhtâr)."
          }
        }
      }
    },
    "safar.infoTitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "About Traveler Status (Safar)"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seferîlik Hakkında"
          }
        }
      }
    },
    "safar.infoWhat" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In Islamic jurisprudence, traveler status (safar) allows a person traveling a certain distance from their home to benefit from certain worship concessions. Turkey's Diyanet (Presidency of Religious Affairs) follows the Hanafi school and sets the travel distance at approximately 90 km."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seferîlik, İslam fıkhında kişinin ikamet ettiği yerden belirli bir mesafe uzağa yolculuk yapması durumunda bazı ibadet kolaylıklarından faydalanmasını sağlayan bir hükümdür. Diyanet İşleri Başkanlığı, Hanefî mezhebine göre seferîlik mesafesini yaklaşık 90 km olarak esas alır."
          }
        }
      }
    },
    "safar.locationNote" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your location is not stored."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konumunuz kaydedilmez."
          }
        }
      }
    },
