    "safar.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calculate the direct distance between your home city and current location."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ev şehriniz ile anlık konumunuz arasındaki kuş uçuşu mesafeyi hesaplayın."
          }
        }
      }
    },
    "safar.disclaimer": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This information is for educational purposes only and does not constitute a religious ruling (fatwa). For definitive guidance, consult the Diyanet or a qualified religious authority."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu bilgiler bilgilendirme amaçlıdır, fetva niteliği taşımaz. Kesin hüküm için Diyanet İşleri Başkanlığı'na veya yetkili bir din görevlisine danışınız."
          }
        }
      }
    },
    "safar.distance": {
