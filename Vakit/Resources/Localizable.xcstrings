    "school.diyanetNote": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Diyanet prayer tables match the Standard Asr calculation (shadow = 1× object height), so Standard is selected automatically. You can change this if you prefer."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Diyanet namaz vakti tabloları Standart ikindi hesabıyla (gölge = cismin 1 katı) eşleşir; bu yüzden Standart otomatik seçilir. İsterseniz değiştirebilirsiniz."
          }
        }
      }
    },
    "school.explanation": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Standard (Shafi): Asr begins when shadow = object height. Hanafi: Asr begins when shadow = 2× object height (Asr enters later)."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Standart (Şafi): Gölge boyu cisim boyuna eşit olunca ikindi girer. Hanefi: Gölge boyu cismin 2 katı olunca ikindi girer (daha geç)."
          }
        }
      }
    },
    "school.hanafi": {
      "extractionState": "manual",
