    "account.delete.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This permanently deletes your account and all data on this device — saved locations, qada counts, notification settings and preferences. This cannot be undone."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu işlem hesabını ve bu cihazdaki tüm verilerini (kayıtlı konumlar, kaza sayıları, bildirim ayarları ve tercihler) kalıcı olarak siler. Bu işlem geri alınamaz."
          }
        }
      }
    },
