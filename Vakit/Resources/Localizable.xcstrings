            "state" : "translated",
            "value" : "Get your location once, then hold the phone flat and follow the needle."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konumunuzu bir kez alın, ardından telefonu düz tutarak ibreyi takip edin."
          }
        }
      }
    },
